# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_URL=https://your-app-url.onrender.com
SCOPES=read_orders,read_customers,read_price_rules,write_price_rules

# Database (PostgreSQL — required for persistent storage on Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated browser origins allowed to call the API (e.g.
# https://app.mystorefront.io). Server-to-server callers (the MyStorefront
# edge functions) don't need this. Leave empty to disallow all browser
# cross-origin requests.
ALLOWED_ORIGINS=

# Sessions
SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars
